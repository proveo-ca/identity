@startuml
'==============================================================
' Proveo — PlantUML theme (dark · "Deep Teal")
' On-brand dark canvas. Same palette, macros and role semantics as
' proveo.puml; the canvas is a dark Proveo-teal and <<app>> brightens
' to MAIN_3 so components separate from the background. Grab it with:
'   !include https://raw.githubusercontent.com/proveo-ca/identity/main/proveo-dark.puml
' No FontName is set — PlantUML's default font is used.
'==============================================================

' --- Brand palette --------------------------------------------
!$BLACK    = "#181818"
!$WHITE    = "#FAFAFA"
!$INK      = "#EAF5F3"
!$GRAY_2   = "#585858"
!$GRAY_3   = "#B4B3B3"
!$GRAY_4   = "#E5E4E4"

!$BG       = "#062831"
!$SURFACE  = "#0E3A48"
!$SURF_LN  = "#1C5567"
!$NEUTRAL  = "#8FB9C2"

!$MAIN     = "#005F7F"
!$MAIN_3   = "#00769D"
!$ALT      = "#00BAC6"
!$ALT_1    = "#006B70"
!$ACCENT   = "#CBDB2A"
!$ACCENT_1 = "#818D00"

!$ERROR    = "#CB2000"
!$SUCCESS  = "#009532"

'==============================================================
' Role colours — same semantics as proveo.puml (light).
'   <<app>> MAIN(_3) · <<async>> ACCENT · <<host>> ALT
'   <<cloud>> GRAY_2 · <<db>> GRAY_4 · <<error>> ERROR
'==============================================================
!define COLOR_APP    #00769D
!define COLOR_ASYNC  #CBDB2A
!define COLOR_HOST   #00BAC6
!define COLOR_CLOUD  #585858
!define COLOR_DB     #E5E4E4
!define COLOR_ERROR  #CB2000

!define STYLE_APP    #00769D;text:White
!define STYLE_CLOUD  #585858;text:White
!define STYLE_ERROR  #CB2000;text:White

'==============================================================
' Semantic arrow macros — neutral edges are a muted teal-grey for
' the teal canvas; semantic edges (error red, async lime) keep hue.
'==============================================================
!define ARROW_MAIN     -[#8FB9C2,bold]->
!define ARROW_OPTIONAL -[#8FB9C2,dotted]->
!define ARROW_ERROR    -[#CB2000,bold]->
!define ARROW_QUEUE    -[#CBDB2A,bold]->
!define ARROW_CLOUD    -[#8FB9C2,dashed,bold]->

' --- Legacy aliases (kept so older diagrams keep working) ----
!define COLOR_MAIN #00769D
!define COLOR_ALT #00BAC6
!define COLOR_ACCENT #CBDB2A
!define COLOR_SUCCESS #009532
!define COLOR_GRAY #8FB9C2

!define PATH_MAIN thickness=3
!define PATH_COMMON thickness=1

!define errorLabel(x) <color:#CB2000><b>x</b></color>
!define successLabel(x) <color:#009532><b>x</b></color>
!define dbLabel(x) <color:#8FB9C2><b>x</b></color>

' --- Cleaner primitives ---------------------------------------
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

<style>
  root {
    Shadowing false;
    FontColor $INK;
    BackgroundColor $BG;
    LineColor $NEUTRAL;
  }

  title    { FontColor $ALT; FontSize 20; }
  caption  { FontColor $NEUTRAL; }

  arrow {
    LineColor $NEUTRAL;
    LineThickness 1.5;
    FontColor $INK;
  }

  note {
    BackgroundColor $SURFACE;
    LineColor $SURF_LN;
    FontColor $INK;
    RoundCorner 8;
  }
  legend {
    BackgroundColor $SURFACE;
    LineColor $SURF_LN;
    FontColor $INK;
    RoundCorner 8;
  }

  ' --- Element-type defaults ------------------------------------
  component {
    BackgroundColor $MAIN_3;
    BorderColor $ALT;
    FontColor $WHITE;
    FontSize 14;
    RoundCorner 12;
    Padding 10;
  }
  interface {
    BackgroundColor $ALT;
    BorderColor $MAIN;
    FontColor $BLACK;
  }
  node {
    BackgroundColor $SURFACE;
    BorderColor $SURF_LN;
    FontColor $INK;
    FontSize 14;
    RoundCorner 12;
    Padding 12;
  }
  rectangle {
    BackgroundColor $SURFACE;
    BorderColor $SURF_LN;
    FontColor $INK;
    RoundCorner 12;
  }
  card {
    BackgroundColor $SURFACE;
    BorderColor $SURF_LN;
    FontColor $INK;
    RoundCorner 12;
  }
  database {
    BackgroundColor $SURF_LN;
    BorderColor $ALT;
    FontColor $WHITE;
    FontSize 14;
    RoundCorner 8;
  }
  collections {
    BackgroundColor $MAIN_3;
    BorderColor $ALT;
    FontColor $WHITE;
  }
  actor {
    BackgroundColor $ALT;
    BorderColor $ALT_1;
    FontColor $WHITE;
    FontSize 14;
  }
  queue {
    BackgroundColor $ACCENT;
    BorderColor $ACCENT_1;
    FontColor $BLACK;
    RoundCorner 8;
  }
  cloud {
    BackgroundColor $BG;
    LineColor $ALT;
    FontColor $ALT;
  }
  frame {
    LineColor $ALT;
    FontColor $ALT;
    RoundCorner 10;
  }
  package {
    LineColor $ALT;
    FontColor $ALT;
  }
  folder {
    LineColor $ALT;
    FontColor $ALT;
  }

  ' --- Role stereotypes -----------------------------------------
  .app {
    BackgroundColor $MAIN_3;
    FontColor $WHITE;
    LineColor $ALT;
  }
  .async {
    BackgroundColor $ACCENT;
    FontColor $BLACK;
    LineColor $ACCENT_1;
  }
  .host {
    BackgroundColor $ALT;
    FontColor $BLACK;
    LineColor $ALT_1;
  }
  .cloud {
    BackgroundColor $GRAY_2;
    FontColor $WHITE;
    LineColor $GRAY_2;
  }
  .db {
    BackgroundColor $GRAY_4;
    FontColor $BLACK;
    LineColor $GRAY_2;
  }
  .error {
    BackgroundColor $ERROR;
    FontColor $WHITE;
    LineColor $ERROR;
  }
</style>
@enduml
